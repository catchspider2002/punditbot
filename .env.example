# Reference list of required secrets (documentation only).
# On Cloudflare these are NOT loaded from a committed file:
#   - local dev  -> put them in `.dev.vars` (see .dev.vars.example)
#   - production -> `wrangler secret put NAME`
TELEGRAM_BOT_TOKEN=your_botfather_token
TXLINE_API_KEY=your_txline_key
ANTHROPIC_API_KEY=your_anthropic_key
# Optional - only if doing TTS voice notes:
ELEVENLABS_API_KEY=your_elevenlabs_key
